<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>MPRIMO | Quran, Hadith & Science | Prayer Times & Masjid Locator</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', 'Amiri', 'Traditional Arabic', serif;
            background: linear-gradient(135deg, #0a2a0a 0%, #0a0a2e 100%);
            min-height: 100vh;
            padding: 20px;
            color: #fff;
        }
        
        .container {
            max-width: 1400px;
            margin: 0 auto;
        }
        
        .header {
            text-align: center;
            margin-bottom: 40px;
            padding: 30px;
            background: rgba(0,0,0,0.4);
            border-radius: 25px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,215,0,0.3);
        }
        
        .header h1 {
            font-size: 2.5rem;
            background: linear-gradient(135deg, #FFD700, #00aa44, #4ECDC4);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        
        .creator-name {
            font-size: 1.2rem;
            margin-top: 10px;
            color: #FFD700;
            letter-spacing: 2px;
        }
        
        .creator-name span {
            background: rgba(0,0,0,0.5);
            padding: 5px 15px;
            border-radius: 30px;
            display: inline-block;
        }
        
        /* Prayer & Masjid Section */
        .prayer-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .prayer-card {
            background: rgba(0,0,0,0.5);
            border-radius: 20px;
            padding: 20px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,215,0,0.3);
        }
        
        .prayer-title {
            color: #FFD700;
            font-size: 1.2rem;
            margin-bottom: 15px;
            border-left: 3px solid #FFD700;
            padding-left: 10px;
        }
        
        /* Masjid Locator */
        .masjid-container {
            text-align: center;
            padding: 10px;
        }
        
        .masjid-icon {
            font-size: 3rem;
            margin-bottom: 10px;
        }
        
        .masjid-info {
            background: rgba(0,170,68,0.15);
            border-radius: 15px;
            padding: 15px;
            margin: 15px 0;
        }
        
        .masjid-name {
            font-size: 1.2rem;
            color: #FFD700;
            font-weight: bold;
            margin-bottom: 5px;
        }
        
        .masjid-distance {
            font-size: 1rem;
            color: #00cc44;
            margin-bottom: 5px;
        }
        
        .masjid-address {
            font-size: 0.8rem;
            color: #aaa;
        }
        
        .drive-btn {
            background: linear-gradient(135deg, #FFD700, #00aa44);
            color: #000;
            border: none;
            padding: 12px 25px;
            border-radius: 50px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
            margin-top: 15px;
            width: 100%;
            transition: transform 0.2s;
        }
        
        .drive-btn:hover {
            transform: scale(1.02);
        }
        
        .location-btn {
            background: #00aa44;
            border: 1px solid #FFD700;
            padding: 10px 20px;
            border-radius: 30px;
            cursor: pointer;
            width: 100%;
            font-size: 1rem;
            margin-top: 10px;
        }
        
        .location-btn:hover {
            background: #FFD700;
            color: #000;
        }
        
        .masjid-list {
            margin-top: 15px;
            max-height: 250px;
            overflow-y: auto;
        }
        
        .masjid-item {
            background: rgba(0,0,0,0.3);
            padding: 10px;
            border-radius: 10px;
            margin-bottom: 8px;
            cursor: pointer;
            transition: all 0.2s;
            text-align: left;
        }
        
        .masjid-item:hover {
            background: rgba(255,215,0,0.2);
            transform: translateX(5px);
        }
        
        .masjid-item-name {
            font-weight: bold;
            color: #FFD700;
        }
        
        .masjid-item-dist {
            font-size: 0.7rem;
            color: #00cc44;
        }
        
        /* Prayer Times (Adhan completely removed) */
        .prayer-times {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-top: 10px;
        }
        
        .prayer-item {
            background: rgba(0,0,0,0.3);
            padding: 10px;
            border-radius: 12px;
            text-align: center;
        }
        
        .prayer-name {
            font-size: 0.8rem;
            color: #FFD700;
        }
        
        .prayer-time {
            font-size: 1.1rem;
            font-weight: bold;
            font-family: monospace;
        }
        
        .next-prayer {
            background: #00aa44;
            border-radius: 12px;
            padding: 12px;
            margin-top: 15px;
            text-align: center;
        }
        
        /* Search Section (Hadith + Arabic + Modern English) */
        .search-card {
            background: rgba(0,0,0,0.5);
            border-radius: 25px;
            padding: 30px;
            margin-bottom: 30px;
            backdrop-filter: blur(10px);
        }
        
        .search-box {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            justify-content: center;
            margin-bottom: 20px;
        }
        
        .search-box input {
            flex: 2;
            min-width: 300px;
            font-size: 1.1rem;
            padding: 15px 20px;
            background: #2a2a3e;
            color: #fff;
            border: 1px solid #FFD700;
            border-radius: 15px;
        }
        
        .search-btn {
            background: linear-gradient(135deg, #FFD700, #00aa44);
            color: #000;
            border: none;
            padding: 15px 35px;
            border-radius: 50px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
        }
        
        .mode-selector {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        
        .mode-btn {
            background: #2a2a3e;
            padding: 8px 25px;
            border-radius: 30px;
            cursor: pointer;
            border: 1px solid #FFD700;
        }
        
        .mode-btn.active {
            background: #FFD700;
            color: #000;
        }
        
        .suggestion-chips {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: center;
            margin-top: 15px;
        }
        
        .chip {
            background: #2a2a3e;
            padding: 8px 18px;
            border-radius: 30px;
            font-size: 0.85rem;
            cursor: pointer;
            border: 1px solid #FFD700;
        }
        
        .chip:hover {
            background: #FFD700;
            color: #000;
        }
        
        .results-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(550px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }
        
        .result-card {
            background: rgba(0,0,0,0.65);
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid #333;
            transition: all 0.3s;
            animation: fadeIn 0.4s ease;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .result-card:hover {
            transform: translateY(-5px);
            border-color: #FFD700;
        }
        
        .result-header {
            background: rgba(0,0,0,0.5);
            padding: 15px 20px;
            border-bottom: 1px solid #333;
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 10px;
        }
        
        .result-surah {
            color: #FFD700;
            font-weight: bold;
        }
        
        .arabic-text {
            font-size: 1.3rem;
            font-family: 'Amiri', 'Traditional Arabic', serif;
            color: #00cc44;
            text-align: right;
            direction: rtl;
            padding: 15px;
            background: rgba(0,0,0,0.3);
            border-radius: 12px;
            margin-bottom: 15px;
            line-height: 1.8;
        }
        
        .english-text {
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 15px;
            color: #f0f0f0;
        }
        
        .audio-player {
            background: rgba(0,0,0,0.3);
            padding: 10px;
            border-radius: 10px;
            margin: 10px 0;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        
        .play-btn {
            background: #00aa44;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 25px;
            cursor: pointer;
        }
        
        .science-box {
            background: rgba(0,170,68,0.15);
            border-left: 3px solid #00cc44;
            padding: 15px;
            margin: 15px 0;
            border-radius: 8px;
        }
        
        .science-title {
            color: #00cc44;
            font-weight: bold;
            margin-bottom: 10px;
        }
        
        /* Meaning & topic badges */
        .meaning-badge {
            display: inline-block;
            background: #FFD700;
            color: #000;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 0.75rem;
            margin-bottom: 12px;
            font-weight: bold;
        }
        
        .topic-tag {
            display: inline-block;
            background: #4ECDC4;
            color: #000;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.7rem;
            margin-left: 8px;
        }
        
        .loading {
            text-align: center;
            padding: 60px;
            font-size: 1.2rem;
            color: #FFD700;
        }
        
        .loading::after {
            content: '';
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid #FFD700;
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-left: 10px;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        .no-results {
            text-align: center;
            padding: 60px;
            color: #888;
        }
        
        .footer {
            text-align: center;
            margin-top: 50px;
            padding: 25px;
            color: #555;
            border-top: 1px solid #333;
        }
        
        @media (max-width: 768px) {
            .results-grid { grid-template-columns: 1fr; }
            .header h1 { font-size: 1.6rem; }
            .prayer-times { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1>🔬 القرآن والعلم | Quran & Science</h1>
        <div class="creator-name"><span>✨ Created by: MPRIMO ✨</span></div>
        <p>Search ANY word in the Quran & Hadith • Arabic + Modern English Translation • Prayer Times • Nearest Masjid</p>
    </div>
    
    <!-- Prayer Times & Masjid Locator Section (Adhan completely removed) -->
    <div class="prayer-section">
        <div class="prayer-card">
            <div class="prayer-title">🕌 Find Nearest Masjid</div>
            <div class="masjid-container">
                <div class="masjid-icon">🕌</div>
                <button class="location-btn" onclick="findNearestMasjid()">📍 Find Mosques Near Me</button>
                
                <div id="masjidInfo" class="masjid-info" style="display: none;">
                    <div class="masjid-name" id="masjidName">Loading...</div>
                    <div class="masjid-distance" id="masjidDistance">---</div>
                    <div class="masjid-address" id="masjidAddress">---</div>
                    <button class="drive-btn" id="driveBtn" onclick="openMaps()">🚗 Drive / Navigate 🧭</button>
                </div>
                
                <div id="masjidList" class="masjid-list"></div>
                <div class="instruction-text" style="margin-top: 10px;">
                    📍 Click "Find Mosques Near Me" to locate the closest masjids<br>
                    🚗 Click "Drive / Navigate" to open Google Maps directions
                </div>
            </div>
        </div>
        
        <div class="prayer-card">
            <div class="prayer-title">🕌 Prayer Times</div>
            <div id="locationName" style="font-size:0.85rem; color:#aaa; margin-bottom:10px;">📍 Allow location to see prayer times</div>
            <div class="prayer-times" id="prayerTimesList">
                <div class="prayer-item"><div class="prayer-name">Fajr</div><div class="prayer-time" id="fajr">--:--</div></div>
                <div class="prayer-item"><div class="prayer-name">Dhuhr</div><div class="prayer-time" id="dhuhr">--:--</div></div>
                <div class="prayer-item"><div class="prayer-name">Asr</div><div class="prayer-time" id="asr">--:--</div></div>
                <div class="prayer-item"><div class="prayer-name">Maghrib</div><div class="prayer-time" id="maghrib">--:--</div></div>
                <div class="prayer-item"><div class="prayer-name">Isha</div><div class="prayer-time" id="isha">--:--</div></div>
            </div>
            <div class="next-prayer" id="nextPrayer">
                ⏰ Enable location to see next prayer
            </div>
        </div>
    </div>
    
    <!-- ENHANCED SEARCH CARD (Hadith + Meaning + Arabic + Modern English + Audio) -->
    <div class="search-card">
        <div class="mode-selector">
            <div class="mode-btn active" id="modeQuranBtn" onclick="setMode('quran')">📖 Quran & Hadith Search (Any Word)</div>
            <div class="mode-btn" id="modeScienceBtn" onclick="setMode('science')">🔬 Scientific Miracles</div>
        </div>
        
        <div class="search-box">
            <input type="text" id="searchInput" placeholder="Type ANY word: mercy, justice, woman, prayer, charity, love, patience..." autocomplete="off">
            <button class="search-btn" id="searchBtn">🔍 Search Quran & Hadith</button>
        </div>
        
        <div class="suggestion-chips" id="suggestionChips"></div>
    </div>
    
    <div id="resultsContainer">
        <div id="resultsGrid"></div>
    </div>
    
    <div class="footer">
        <p>🌟 Created by MPRIMO | Quran API + Authentic Hadith (Bukhari, Muslim, Abu Dawud, Tirmidhi, Nasai, Ibn Majah) | Arabic + Modern English | Prayer Times | Nearest Masjid</p>
        <p>📞 Contact: ukdesigner62@gmail.com | WhatsApp: +447492166072</p>
    </div>
</div>

<script>
    // ========== MASJID LOCATOR + PRAYER TIMES (Adhan removed) ==========
    let userLat = null, userLon = null;
    let closestMasjids = [];
    let currentAudio = null;
    
    function findNearestMasjid() {
        if (navigator.geolocation) {
            showToast('📍 Finding mosques near you...');
            navigator.geolocation.getCurrentPosition(async (position) => {
                userLat = position.coords.latitude; userLon = position.coords.longitude;
                const query = `[out:json];(node["amenity"="place_of_worship"]["religion"="muslim"](around:5000,${userLat},${userLon});way["amenity"="place_of_worship"]["religion"="muslim"](around:5000,${userLat},${userLon});relation["amenity"="place_of_worship"]["religion"="muslim"](around:5000,${userLat},${userLon}););out body;>;out skel qt;`;
                try {
                    const response = await fetch(`https://overpass-api.de/api/interpreter?data=${encodeURIComponent(query)}`);
                    const data = await response.json();
                    const masjids = [];
                    for (let el of data.elements || []) {
                        if (el.type === 'node' && el.lat && el.lon) {
                            const distance = calculateDistance(userLat, userLon, el.lat, el.lon);
                            masjids.push({ id: el.id, name: el.tags?.name || 'Mosque', lat: el.lat, lon: el.lon, distance: distance, address: el.tags?.addr_street || 'Maps' });
                        }
                    }
                    masjids.sort((a,b)=>a.distance-b.distance);
                    closestMasjids = masjids.slice(0,10);
                    displayMasjids(closestMasjids);
                    if (closestMasjids.length) displayNearestMasjid(closestMasjids[0]);
                    else findMosquesViaGoogleMaps();
                } catch(e) { findMosquesViaGoogleMaps(); }
                await getPrayerTimes(userLat, userLon);
            }, () => showToast('⚠️ Please enable location'));
        } else showToast('⚠️ Geolocation not supported');
    }
    function findMosquesViaGoogleMaps() { window.open(`https://www.google.com/maps/search/mosque+near+me/@${userLat},${userLon},14z`, '_blank'); showToast('📍 Opening Google Maps'); }
    function calculateDistance(lat1,lon1,lat2,lon2){ const R=6371; const dLat=(lat2-lat1)*Math.PI/180; const dLon=(lon2-lon1)*Math.PI/180; const a=Math.sin(dLat/2)**2+Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2; return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a)); }
    function displayMasjids(masjids){ const container=document.getElementById('masjidList'); if(masjids.length===0){ container.innerHTML='<div style="text-align:center;color:#888;">No mosques found</div>'; return; }
        container.innerHTML='<div style="font-size:0.7rem;color:#aaa;margin-bottom:5px;">📋 Nearby Mosques:</div>';
        for(let i=0;i<Math.min(masjids.length,5);i++){ const m=masjids[i]; const distText=m.distance<1?`${(m.distance*1000).toFixed(0)}m`:`${m.distance.toFixed(1)}km`;
            container.innerHTML+=`<div class="masjid-item" onclick="selectMasjid(${i})"><div class="masjid-item-name">🕌 ${escapeHtml(m.name)}</div><div class="masjid-item-dist">📏 ${distText} away</div></div>`;
        }
    }
    function selectMasjid(idx){ const m=closestMasjids[idx]; if(m) displayNearestMasjid(m); }
    function displayNearestMasjid(m){ const distText=m.distance<1?`${(m.distance*1000).toFixed(0)} meters`:`${m.distance.toFixed(1)} km`;
        document.getElementById('masjidInfo').style.display='block';
        document.getElementById('masjidName').innerHTML=`🕌 ${escapeHtml(m.name)}`;
        document.getElementById('masjidDistance').innerHTML=`📏 ${distText} from your location`;
        document.getElementById('masjidAddress').innerHTML=`📍 ${escapeHtml(m.address)}`;
        window.selectedMasjid=m;
    }
    function openMaps(){ if(window.selectedMasjid) window.open(`https://www.google.com/maps/dir/?api=1&destination=${window.selectedMasjid.lat},${window.selectedMasjid.lon}&travelmode=driving`,'_blank'); else if(userLat&&userLon) window.open(`https://www.google.com/maps/search/mosque+near+me/@${userLat},${userLon},14z`,'_blank'); else showToast('📍 Please find mosques first'); }
    
    // Prayer Times (no adhan)
    async function getPrayerTimes(lat,lon){ try{ const date=new Date(); const url=`https://api.aladhan.com/v1/timings/${date.getDate()}-${date.getMonth()+1}-${date.getFullYear()}?latitude=${lat}&longitude=${lon}&method=2`; const res=await fetch(url); const data=await res.json(); if(data?.data?.timings){ const t=data.data.timings; document.getElementById('fajr').innerHTML=t.Fajr; document.getElementById('dhuhr').innerHTML=t.Dhuhr; document.getElementById('asr').innerHTML=t.Asr; document.getElementById('maghrib').innerHTML=t.Maghrib; document.getElementById('isha').innerHTML=t.Isha; const now=new Date(); const cur=now.getHours()*60+now.getMinutes(); const prayers=[{name:'Fajr',time:t.Fajr},{name:'Dhuhr',time:t.Dhuhr},{name:'Asr',time:t.Asr},{name:'Maghrib',time:t.Maghrib},{name:'Isha',time:t.Isha}]; for(let p of prayers){ let [h,m]=p.time.split(':').map(Number); let mins=h*60+m; if(mins>cur){ document.getElementById('nextPrayer').innerHTML=`⏰ Next Prayer: <strong>${p.name}</strong> in ${Math.floor((mins-cur)/60)}h ${(mins-cur)%60}m`; break; } }
            try{ const geo=await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`); const geoData=await geo.json(); document.getElementById('locationName').innerHTML=`📍 ${geoData.address?.city||geoData.address?.town||'Your Location'}`; }catch(e){}
        } }catch(e){console.log(e);} }
    
    // ========== ENHANCED ISLAMIC SEARCH (Hadith + Arabic + CLEAR MODERN ENGLISH) ==========
    
    // Meaning for common search terms
    const termMeanings = {
        'mercy': '🤲 Mercy (Rahmah) — Allah’s compassion and forgiveness. "My mercy encompasses all things" (Quran 7:156)',
        'patience': '⏳ Patience (Sabr) — Steadfastness in obedience. "Indeed, Allah is with the patient" (Quran 2:153)',
        'woman': '👩 Woman (Nisa) — Honored and respected. "The best of you are those best to their women" (Hadith)',
        'justice': '⚖️ Justice (Adl) — Fairness and equity. "Stand firmly for justice" (Quran 4:135)',
        'charity': '💝 Charity (Sadaqah/Zakat) — Purifies wealth. "Charity extinguishes sin like water extinguishes fire" (Hadith)',
        'prayer': '🕌 Prayer (Salah) — Connection with Allah five times daily.',
        'forgiveness': '💚 Forgiveness (Maghfirah) — Allah loves to forgive.',
        'love': '❤️ Love (Hubb) — Love for Allah and His Messenger.',
        'knowledge': '📚 Knowledge (Ilm) — Seeking it is an obligation. "Are those who know equal to those who do not know?" (Quran 39:9)'
    };
    
    // Authentic Hadith database (Sahih International style English)
    const hadithDatabase = [
        { reference: 'Sahih al-Bukhari, 13', arabic: 'لا يُؤْمِنُ أَحَدُكُمْ حَتَّى يُحِبَّ لأَخِيهِ مَا يُحِبُّ لِنَفْسِهِ', english: 'None of you truly believes until he loves for his brother what he loves for himself.', keywords: ['love','brother','faith'], topic: 'Love' },
        { reference: 'Sahih al-Bukhari, 6011', arabic: 'الرَّاحِمُونَ يَرْحَمُهُمُ الرَّحْمَنُ', english: 'Those who are merciful will be shown mercy by the Most Merciful.', keywords: ['mercy','merciful'], topic: 'Mercy' },
        { reference: 'Sahih al-Bukhari, 5644', arabic: 'وَالصَّبْرُ ضِيَاءٌ', english: 'Patience is a light.', keywords: ['patience','light'], topic: 'Patience' },
        { reference: 'Sahih Muslim, 2637', arabic: 'لا يؤمن أحدكم حتى يحب لأخيه ما يحب لنفسه', english: 'None of you believes until he loves for his brother what he loves for himself.', keywords: ['love','brother'], topic: 'Love' },
        { reference: 'Sahih Muslim, 2318', arabic: 'الراحمون يرحمهم الرحمن', english: 'The merciful are shown mercy by the Most Merciful.', keywords: ['mercy'], topic: 'Mercy' },
        { reference: 'Sunan Abi Dawud, 2144', arabic: 'خَيْرُكُمْ خَيْرُكُمْ لأَهْلِهِ', english: 'The best of you are those who are best to their womenfolk.', keywords: ['woman','best','family'], topic: 'Women' },
        { reference: 'Jami at-Tirmidhi, 589', arabic: 'الصَّدَقَةُ تُطْفِئُ الْخَطِيئَةَ كَمَا يُطْفِئُ الْمَاءُ النَّارَ', english: 'Charity extinguishes sin as water extinguishes fire.', keywords: ['charity','sadaqah','sin'], topic: 'Charity' },
        { reference: 'Sunan an-Nasai, 4991', arabic: 'لا تدخلون الجنة حتى تؤمنوا ولا تؤمنوا حتى تحابوا', english: 'You will not enter Paradise until you believe, and you will not believe until you love one another.', keywords: ['paradise','faith','love'], topic: 'Love' },
        { reference: 'Sunan Ibn Majah, 224', arabic: 'طَلَبُ الْعِلْمِ فَرِيضَةٌ عَلَى كُلِّ مُسْلِمٍ', english: 'Seeking knowledge is an obligation upon every Muslim.', keywords: ['knowledge','learn','ilm'], topic: 'Knowledge' }
    ];
    
    // Quran API – we fetch both Arabic and modern English (Sahih International)
    const QURAN_SEARCH_API = 'https://api.alquran.cloud/v1/search/';
    const QURAN_AYAH_API = 'https://api.alquran.cloud/v1/ayah/';
    
    function getAudioUrl(surah, verse) { return `https://everyayah.com/data/Abdurrahmaan_As-Sudais_192kbps/${surah.toString().padStart(3,'0')}${verse.toString().padStart(3,'0')}.mp3`; }
    function playAudio(surah, verse, button) {
        if (currentAudio) { currentAudio.pause(); currentAudio = null; document.querySelectorAll('.play-btn').forEach(btn => btn.innerHTML = '🔊 Play'); }
        const audio = new Audio(getAudioUrl(surah, verse));
        currentAudio = audio;
        audio.onplay = () => button.innerHTML = '🎧 Playing...';
        audio.onended = () => { button.innerHTML = '🔊 Play'; currentAudio = null; };
        audio.play().catch(() => button.innerHTML = '🔊 Play');
    }
    
    async function searchQuranWithModernEnglish(term) {
        try {
            const response = await fetch(QURAN_SEARCH_API + encodeURIComponent(term) + '/all/en');
            if (response.ok) {
                const data = await response.json();
                const matches = data?.data?.matches || [];
                const results = [];
                for (let verse of matches.slice(0, 6)) {
                    const surahNum = verse.surah.number;
                    const ayahNum = verse.numberInSurah;
                    let arabicText = verse.text;
                    let englishText = verse.translation || 'Translation available';
                    // fetch the most accurate Arabic from the cloud API
                    try {
                        const [arabRes, engRes] = await Promise.all([
                            fetch(QURAN_AYAH_API + `${surahNum}:${ayahNum}/editions/ar.sahih`),
                            fetch(QURAN_AYAH_API + `${surahNum}:${ayahNum}/editions/en.sahih`)
                        ]);
                        const arabData = await arabRes.json();
                        const engData = await engRes.json();
                        if (arabData?.data) arabicText = arabData.data[0]?.text || arabicText;
                        if (engData?.data) englishText = engData.data[0]?.text || englishText;
                    } catch(e) {}
                    results.push({
                        surahName: verse.surah.name,
                        surahNum: surahNum,
                        ayahNum: ayahNum,
                        arabic: arabicText,
                        english: englishText
                    });
                }
                return results;
            }
        } catch(e) { console.log('Quran API error'); }
        return [];
    }
    
    function searchHadithByTerm(term) {
        const lower = term.toLowerCase();
        return hadithDatabase.filter(h => 
            h.english.toLowerCase().includes(lower) || 
            h.keywords.some(k => lower.includes(k) || k.includes(lower)) ||
            h.topic.toLowerCase().includes(lower)
        );
    }
    
    function getMeaningForTerm(term) {
        const lower = term.toLowerCase();
        for (let key in termMeanings) {
            if (lower.includes(key) || key.includes(lower)) return termMeanings[key];
        }
        return null;
    }
    
    let currentMode = 'quran';
    
    async function performSearch() {
        const searchTerm = document.getElementById('searchInput').value.trim().toLowerCase();
        const resultsGrid = document.getElementById('resultsGrid');
        if (!searchTerm) { resultsGrid.innerHTML = '<div class="no-results">✨ Enter a word to search the Quran or discover scientific miracles</div>'; return; }
        resultsGrid.innerHTML = '<div class="loading">Searching Quran, Hadith...</div>';
        
        if (currentMode === 'quran') {
            const meaning = getMeaningForTerm(searchTerm);
            const quranResults = await searchQuranWithModernEnglish(searchTerm);
            const hadithResults = searchHadithByTerm(searchTerm);
            
            if (quranResults.length === 0 && hadithResults.length === 0 && !meaning) {
                resultsGrid.innerHTML = `<div class="no-results">📭 No results for "${escapeHtml(searchTerm)}". Try: mercy, justice, woman, prayer, charity, love</div>`;
                return;
            }
            
            let html = '<div class="results-grid">';
            // Meaning badge
            if (meaning) {
                html += `<div class="result-card">
                    <div class="result-header"><span class="result-surah">📖 Islamic Meaning</span></div>
                    <div class="result-body" style="padding:20px">
                        <div class="meaning-badge">📚 MEANING & CONTEXT</div>
                        <div class="english-text" style="font-size:1rem;">${escapeHtml(meaning)}</div>
                    </div>
                </div>`;
            }
            // Quran results with ARABIC + modern English
            for (const v of quranResults) {
                html += `<div class="result-card">
                    <div class="result-header"><span class="result-surah">📖 QURAN: ${escapeHtml(v.surahName)} (${v.surahNum}:${v.ayahNum})</span><span class="topic-tag">🕋 Revelation</span></div>
                    <div class="result-body" style="padding:20px">
                        <div class="arabic-text">${escapeHtml(v.arabic)}</div>
                        <div class="english-text">${escapeHtml(v.english)}</div>
                        <div class="audio-player"><button class="play-btn" onclick="playAudio(${v.surahNum}, ${v.ayahNum}, this)">🔊 Play Recitation</button><span style="font-size:0.7rem;margin-left:8px;">🎙️ Sheikh Sudais</span></div>
                    </div>
                </div>`;
            }
            // Hadith results with ARABIC + modern English
            for (const h of hadithResults) {
                html += `<div class="result-card">
                    <div class="result-header"><span class="result-surah">📜 HADITH: ${escapeHtml(h.reference)}</span><span class="topic-tag">🏷️ ${h.topic}</span></div>
                    <div class="result-body" style="padding:20px">
                        <div class="arabic-text">${escapeHtml(h.arabic)}</div>
                        <div class="english-text">${escapeHtml(h.english)}</div>
                    </div>
                </div>`;
            }
            html += '</div>';
            resultsGrid.innerHTML = html;
        } 
        else {  // Science mode preserved
            const scienceDatabase = {
                'baby': { title: '🤰 Human Embryonic Development', explanation: 'The Quran describes human creation in stages: Nutfah → Alaqah → Mudghah → bones → flesh.', surah:23, verse:12, verses:['Surah Al-Mu\'minun (23:12-14)'] },
                'iron': { title: '⚙️ Iron - Sent Down from Space', explanation: 'Iron comes from supernova explosions – Quran states "sent down".', surah:57, verse:25, verses:['Surah Al-Hadid (57:25)'] },
                'sun': { title: '☀️ The Sun\'s Orbit', explanation: 'The sun runs to a fixed resting place – galactic orbit.', surah:36, verse:38, verses:['Surah Ya-Sin (36:38)'] },
                'moon': { title: '🌙 The Moon\'s Reflected Light', explanation: 'Moon reflects sunlight.', surah:71, verse:16, verses:['Surah Nuh (71:16)'] },
                'water': { title: '💧 The Water Cycle', explanation: 'Evaporation, clouds, rain described.', surah:39, verse:21, verses:['Surah Az-Zumar (39:21)'] },
                'mountains': { title: '⛰️ Mountains as Pegs', explanation: 'Mountains have deep roots stabilizing crust.', surah:78, verse:6, verses:['Surah An-Naba (78:6-7)'] },
                'universe': { title: '🌌 Expanding Universe', explanation: '"We are expanding it."', surah:51, verse:47, verses:['Surah Adh-Dhariyat (51:47)'] },
                'big bang': { title: '💥 The Big Bang', explanation: 'Heavens and earth joined then separated.', surah:21, verse:30, verses:['Surah Al-Anbiya (21:30)'] }
            };
            let match = null;
            for (let k in scienceDatabase) if (searchTerm.includes(k) || k.includes(searchTerm)) { match = scienceDatabase[k]; break; }
            if (match) {
                const fetchAyah = async (s,v) => { try{ const res=await fetch(`https://api.alquran.cloud/v1/ayah/${s}:${v}/editions/ar.sahih,en.sahih`); const d=await res.json(); if(d?.data){ return { arabic: d.data.find(e=>e.edition?.identifier==='ar.sahih')?.text||'', english: d.data.find(e=>e.edition?.identifier==='en.sahih')?.text||'' }; } }catch(e){} return null; };
                const qd = await fetchAyah(match.surah, match.verse);
                resultsGrid.innerHTML = `<div class="results-grid"><div class="result-card"><div class="result-header"><span class="result-surah">🔬 SCIENTIFIC MIRACLE</span></div><div class="result-body" style="padding:20px"><div class="science-box"><div class="science-title">${match.title}</div><div>${match.explanation}</div></div>${qd?`<div class="arabic-text">${qd.arabic}</div><div class="english-text">${qd.english}</div><div class="audio-player"><button class="play-btn" onclick="playAudio(${match.surah}, ${match.verse}, this)">🔊 Play Recitation</button></div>`:''}</div></div></div>`;
            } else {
                resultsGrid.innerHTML = `<div class="no-results">🔍 Try: baby, iron, sun, moon, water, mountains, universe, big bang</div>`;
            }
        }
    }
    
    function setMode(mode) {
        currentMode = mode;
        document.getElementById('modeQuranBtn').classList.toggle('active', mode === 'quran');
        document.getElementById('modeScienceBtn').classList.toggle('active', mode === 'science');
        const searchBtn = document.getElementById('searchBtn');
        const searchInput = document.getElementById('searchInput');
        if (mode === 'quran') {
            searchBtn.innerHTML = '🔍 Search Quran & Hadith';
            searchInput.placeholder = 'Type ANY word: mercy, justice, woman, prayer, charity, love...';
            document.getElementById('suggestionChips').innerHTML = `<span class="chip" onclick="searchWord('mercy')">🤲 Mercy</span><span class="chip" onclick="searchWord('justice')">⚖️ Justice</span><span class="chip" onclick="searchWord('woman')">👩 Woman</span><span class="chip" onclick="searchWord('peace')">🕊️ Peace</span><span class="chip" onclick="searchWord('love')">❤️ Love</span><span class="chip" onclick="searchWord('charity')">💝 Charity</span><span class="chip" onclick="searchWord('patience')">⏳ Patience</span>`;
        } else {
            searchBtn.innerHTML = '🔬 Discover Scientific Miracle';
            searchInput.placeholder = 'Search: baby, iron, sun, moon, water, mountains, universe...';
            document.getElementById('suggestionChips').innerHTML = `<span class="chip" onclick="searchWord('baby')">🤰 Embryo</span><span class="chip" onclick="searchWord('iron')">⚙️ Iron</span><span class="chip" onclick="searchWord('sun')">☀️ Sun</span><span class="chip" onclick="searchWord('universe')">🌌 Universe</span>`;
        }
    }
    async function searchWord(word) { document.getElementById('searchInput').value = word; await performSearch(); }
    function escapeHtml(text) { if (!text) return ''; const div = document.createElement('div'); div.textContent = text; return div.innerHTML; }
    function showToast(msg) { const t = document.createElement('div'); t.className = 'toast'; t.style.cssText = 'position:fixed; bottom:20px; left:50%; transform:translateX(-50%); background:#00aa44; color:white; padding:10px 20px; border-radius:10px; z-index:9999; animation:fadeOut 3s ease; white-space:nowrap;'; t.innerHTML = msg; document.body.appendChild(t); setTimeout(()=>t.remove(),3000); }
    
    // Event listeners
    document.getElementById('searchBtn').addEventListener('click', performSearch);
    document.getElementById('searchInput').addEventListener('keypress', e => { if (e.key === 'Enter') performSearch(); });
    setTimeout(() => { if (navigator.geolocation) navigator.geolocation.getCurrentPosition(async (pos) => { userLat = pos.coords.latitude; userLon = pos.coords.longitude; await getPrayerTimes(userLat, userLon); }, () => {}); }, 1000);
    setMode('quran');
    setTimeout(() => showToast('🏆 MPRIMO | Quran & Hadith with Arabic + Modern English | Prayer Times | Masjid Locator'), 1000);
</script>

<style>
    @keyframes fadeOut {
        0% { opacity: 1; }
        70% { opacity: 1; }
        100% { opacity: 0; visibility: hidden; }
    }
    .toast { animation: fadeOut 3s ease; }
</style>
</body>
</html>
